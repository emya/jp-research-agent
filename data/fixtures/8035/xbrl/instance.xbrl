<?xml version="1.0" encoding="UTF-8"?>
<!--
  Illustrative SAMPLE EDINET XBRL instance for offline MVP execution.
  Element names (jppfs_cor:*, jpcrp_cor:*, jpdei_cor:*) and context IDs
  (CurrentYearDuration, PriorYearInstant, ...) follow real EDINET conventions.
  Figures and narrative are illustrative, not authoritative.
-->
