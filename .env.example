# Copy this file to .env and fill in your keys. .env is gitignored.

# EDINET API v2 Subscription-Key — enables live filing downloads.
EDINET_API_KEY=

# --- Memo generation (set EITHER one; leave both blank for offline templates) ---
# Anthropic API key — uses Claude (default preference when both are set).
ANTHROPIC_API_KEY=
# OpenAI API key — used when ANTHROPIC_API_KEY is blank.
OPENAI_API_KEY=

# Optional: force a provider when both keys are present (anthropic | openai).
# LLM_PROVIDER=anthropic
# Optional: override default models.
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_MODEL=gpt-4.1
